hardstatus      alwayslastline "%{.kW}%-w%{.bW}%n %t%{-}%+w %=%{..G} %H %{..Y}"
shell           "bash"
startup_message off
vbell           off
altscreen       on
attrcolor       b ".I"
bce             on
deflogin        off                 #Get rid of annoying utmp message under cygwin
autodetach      on


termcapinfo     * ti@:te@
term            screen-256color
terminfo        rxvt* 'Co#256:AB=\E[48;5;%dm:AF=\E[38;5;%dm'
