hardstatus      alwayslastline "%{.kW}%-w%{.bk}%n %t%{-}%+w %=%{..G} %H %{..Y}"
shell           "bash"
startup_message off
vbell           off
altscreen       on
attrcolor       b ".I"
defbce          on
deflogin        off                 #Get rid of annoying utmp message under cygwin
autodetach      on

term            screen-256color
termcapinfo     * ti@:te@
terminfo        rxvt* 'Co#256:AB=\E[48;5;%dm:AF=\E[38;5;%dm'

# Window numbering starts at 1
bind            c screen 1
bind            0 select 10
screen          1
